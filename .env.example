# --- AI providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RECRAFT_API_KEY=
FAL_KEY=
GOOGLE_AI_KEY=
# Optional: Hugging Face (currently unused but reserved for future provider routing).
HF_TOKEN=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Freemium gating ---
# Random 32+ byte string. Used to HMAC the device-id cookie.
DEVICE_COOKIE_SECRET=
# Global daily ceiling on free generations (circuit breaker against abuse).
FREE_STORIES_PER_DAY_GLOBAL=200

# --- Stripe (live or test mode) ---
STRIPE_SECRET_KEY=
# Primary webhook signing secret (live in production).
STRIPE_WEBHOOK_SECRET=
# Optional fallback used by the webhook handler when an event was signed with
# the test-mode endpoint. Leave blank if you don't run test-mode replays.
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_PRICE_PACK_1=
STRIPE_PRICE_PACK_3=
STRIPE_PRICE_PACK_10=

# --- Resend (transactional email for magic link + provider alerts) ---
RESEND_API_KEY=
EMAIL_FROM="Kids Books <hello@example.com>"
# Operator inbox for provider 402/429 alerts (debounced to 1/hour per provider)
ALERT_EMAIL=

# --- App URL used in Stripe success/cancel + magic link ---
# REQUIRED in production. In dev it falls back to the request origin.
# In production an unset APP_URL would let an attacker spoof the Host header
# and inject a phishing URL into the recovery email — the app refuses to boot
# in production without this set.
APP_URL=http://localhost:3000

# --- Cron secret for /api/cron/resume-stories ---
# Vercel cron sends `Authorization: Bearer <CRON_SECRET>`. If unset, the
# endpoint accepts unauthenticated requests — fine for local dev but unsafe
# in production. Set this to a random 32+ byte string in any deployed env.
CRON_SECRET=
